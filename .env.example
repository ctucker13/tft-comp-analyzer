# TFT Set 15: K.O. Coliseum Composition Analyzer
# Environment Configuration Template

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Riot Games Development API Key (expires every 24 hours)
# Get yours at: https://developer.riotgames.com/
RIOT_API_KEY=your_riot_development_key_here

# Anthropic Claude API Key (recommended for TFT analysis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API Key (alternative to Anthropic)
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# LLM Provider Selection
# Options: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# =============================================================================
# RIOT API CONFIGURATION
# =============================================================================

# TFT Region Settings
# European Options: euw1 (Europe West), eun1 (Nordic & East), tr1 (Turkey), ru1 (Russia)
# North American: na1 (North America)
# Asian: kr (Korea), jp1 (Japan)
RIOT_REGION=euw1

# =============================================================================
# TFT SET 15 CONFIGURATION
# =============================================================================

# Current TFT Set Information
CURRENT_TFT_SET=15
CURRENT_PATCH=15.17
TFT_SET_NAME=K.O. Coliseum

# =============================================================================
# ANALYSIS SETTINGS
# =============================================================================

# Match Analysis Targets
TARGET_MATCH_COUNT=30           # Target number of matches to analyze
DAYS_BACK_FOR_MATCHES=7         # Look back this many days for matches
MAX_PLAYERS_TO_ANALYZE=10       # Maximum number of players to process

# =============================================================================
# FILTERING OPTIONS
# =============================================================================

# Patch Filtering
# Set to "true" to only analyze matches from patch 15.3+ (released 2025/08/26)
# Set to "false" to include all Set 15 matches regardless of patch
REQUIRE_PATCH_15_3=false

# Time-based Filtering
# Set to "true" to prefer matches from the last 24 hours
# Set to "false" to use the DAYS_BACK_FOR_MATCHES setting
USE_24H_FILTER=false

# =============================================================================
# PERFORMANCE & DEVELOPMENT SETTINGS
# =============================================================================

# API Response Caching
# Set to "true" to enable caching (recommended for development)
# Set to "false" to always fetch fresh data
USE_CACHE=true

# Player Selection Strategy
# Set to "true" to analyze recent performance and prioritize winning players
# Set to "false" to use players in rank order (LP-based)
PRIORITIZE_WINNERS=true

# =============================================================================
# OPTIONAL ADVANCED SETTINGS
# =============================================================================

# Model Configuration (uncomment to customize)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o

# Rate Limiting (uncomment to customize)
# API_DELAY_SECONDS=8

# Development Mode (uncomment to enable additional debugging)
# DEBUG_MODE=false
# LOG_LEVEL=INFO